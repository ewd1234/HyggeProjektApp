@using System.Threading.Tasks

<div class="dice-wrapper">
    <div class="dice @diceAnimationClass" style="@diceRotationStyle">
        <div class="side one">
            <span class="dot"></span>
        </div>

        <div class="side two">
            <span class="dot"></span>
            <span class="dot"></span>
        </div>

        <div class="side three">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
        </div>

        <div class="side four">
            <div class="column">
                <span class="dot"></span>
                <span class="dot"></span>
            </div>
            <div class="column">
                <span class="dot"></span>
                <span class="dot"></span>
            </div>
        </div>

        <div class="side five">
            <div class="column">
                <span class="dot"></span>
                <span class="dot"></span>
            </div>
            <div class="column flex-center">
                <span class="dot"></span>
            </div>
            <div class="column">
                <span class="dot"></span>
                <span class="dot"></span>
            </div>
        </div>

        <div class="side six">
            <div class="column">
                <span class="dot"></span>
                <span class="dot"></span>
                <span class="dot"></span>
            </div>
            <div class="column">
                <span class="dot"></span>
                <span class="dot"></span>
                <span class="dot"></span>
            </div>
        </div>
    </div>
</div>

<div class="text-center mt-4">
    <button class="dice-roll-btn" @onclick="RollDice" disabled="@isRolling">
        @((isRolling) ? "Ruller..." : "Kast Terning")
    </button>
</div>

@code {
    [Parameter] public EventCallback<int> OnRollFinished { get; set; }

    private string diceAnimationClass = "";
    private string diceRotationStyle = "";
    private bool isRolling = false;
    private Random rng = new Random();

    private async Task RollDice()
    {
        if (isRolling) return;

        isRolling = true;
        diceAnimationClass = "rolling";
        StateHasChanged();

        await Task.Delay(1000); // Vild spin-fase

        int roll = rng.Next(1, 7);
        diceAnimationClass = ""; // Stop spin
        StateHasChanged();

        await Task.Delay(50); // Lille CSS-pause

        // Roterer til den rigtige side med ekstra omgang for fed effekt
        diceRotationStyle = roll switch
        {
            1 => "transform: rotateY(720deg) rotateX(720deg);",
            2 => "transform: rotateY(720deg) rotateX(810deg);",
            3 => "transform: rotateY(630deg) rotateX(720deg);",
            4 => "transform: rotateY(810deg) rotateX(720deg);",
            5 => "transform: rotateY(720deg) rotateX(630deg);",
            6 => "transform: rotateY(900deg) rotateX(720deg);",
            _ => ""
        };

        StateHasChanged();

        await Task.Delay(2000); // Vent på landing

        isRolling = false;
        await OnRollFinished.InvokeAsync(roll);
    }
}